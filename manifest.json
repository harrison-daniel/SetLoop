{
  "manifest_version": 3,
  "name": "SetLoop",
  "version": "1.0.0",
  "description": "Voice-controlled video looping. Say 'loop last 30 at half speed' to drill any section hands-free. Zero data collection — mic only active when you enable it.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-voice": {
      "suggested_key": { "default": "Alt+V" },
      "description": "Toggle voice control on/off"
    },
    "quick-bookmark": {
      "suggested_key": { "default": "Alt+B" },
      "description": "Bookmark current video timestamp"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
