{
  "manifest_version": 3,
  "name": "SetLoop",
  "version": "2.0.0",
  "minimum_chrome_version": "116",
  "description": "Voice-controlled video looping. Say 'loop last 30 at half speed' to drill any section hands-free. Fully local — mic audio never leaves your device.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "offscreen"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-voice": {
      "suggested_key": { "default": "Alt+V" },
      "description": "Toggle voice control on/off"
    },
    "quick-bookmark": {
      "suggested_key": { "default": "Alt+B" },
      "description": "Bookmark current video timestamp"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
